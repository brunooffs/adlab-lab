# ── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9094    # from your Mac (host access)
KAFKA_TOPIC=clickstream
EVENTS_PER_SECOND=10

# ── Spark ──────────────────────────────────────────────────────────────────
SPARK_MASTER=spark://spark-master:7077
CHECKPOINT_DIR=/tmp/spark-checkpoints

# ── Elasticsearch ──────────────────────────────────────────────────────────
ES_NODES=elasticsearch
ES_PORT=9200
